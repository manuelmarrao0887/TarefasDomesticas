<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Tarefas Casa — Ana</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FAFAF8;
      --surface: #FFFFFF;
      --surface-alt: #F3F2EE;
      --text: #1A1A18;
      --text-mid: #6B6B65;
      --text-light: #9C9C95;
      --accent: #2563EB;
      --accent-hover: #1D4ED8;
      --accent-bg: #EFF6FF;
      --accent-border: #BFDBFE;
      --border: #E5E5E0;
      --border-hover: #D1D1CA;
      --radius: 10px;
      --radius-lg: 14px;
      --chip-radius: 22px;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
      --font: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
    }

    .app {
      max-width: 460px;
      margin: 0 auto;
      padding: 1.25rem 1rem 3rem;
    }

    .app-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 1.75rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
    }

    .app-icon {
      width: 38px;
      height: 38px;
      background: var(--accent);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .app-title {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .app-subtitle {
      font-size: 13px;
      color: var(--text-light);
    }

    .section-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 1.5rem 0 0.6rem;
    }

    .day-selector {
      display: flex;
      gap: 8px;
      margin-bottom: 0.25rem;
    }

    .day-btn {
      flex: 1;
      padding: 10px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface);
      font-size: 14px;
      font-family: var(--font);
      cursor: pointer;
      text-align: center;
      transition: all 0.15s;
      color: var(--text);
      font-weight: 500;
    }

    .day-btn:hover { border-color: var(--border-hover); }

    .day-btn.active {
      background: var(--accent-bg);
      border-color: var(--accent-border);
      color: var(--accent);
    }

    .task-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 6px;
      cursor: pointer;
      transition: all 0.15s;
      user-select: none;
      background: var(--surface);
    }

    .task-row:hover { border-color: var(--border-hover); box-shadow: var(--shadow-sm); }

    .task-row.checked {
      background: var(--accent-bg);
      border-color: var(--accent-border);
    }

    .task-check {
      width: 22px;
      height: 22px;
      border-radius: 6px;
      border: 1.5px solid var(--border-hover);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.15s;
    }

    .task-row.checked .task-check {
      background: var(--accent);
      border-color: var(--accent);
    }

    .task-check svg { opacity: 0; transition: opacity 0.15s; }
    .task-row.checked .task-check svg { opacity: 1; }

    .task-label { font-size: 14px; flex: 1; font-weight: 500; }

    .task-freq {
      font-size: 11px;
      color: var(--text-light);
      background: var(--surface-alt);
      padding: 3px 8px;
      border-radius: var(--chip-radius);
      white-space: nowrap;
      font-weight: 500;
    }

    .task-row.checked .task-freq { background: rgba(37,99,235,0.1); color: var(--accent); }

    .next-date { font-size: 11px; color: var(--accent); margin-top: 2px; font-weight: 400; }

    .meals-panel {
      padding: 10px 14px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 6px;
    }

    .meals-grid { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }

    .meal-chip {
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: var(--chip-radius);
      font-size: 13px;
      cursor: pointer;
      transition: all 0.15s;
      user-select: none;
      background: var(--surface);
      color: var(--text);
      font-family: var(--font);
    }

    .meal-chip:hover { border-color: var(--border-hover); }

    .meal-chip.selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .sub-label {
      font-size: 12px;
      color: var(--text-light);
      margin: 8px 0 4px;
    }

    textarea, input[type="text"] {
      width: 100%;
      padding: 9px 12px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 14px;
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      resize: vertical;
      line-height: 1.5;
    }

    textarea:focus, input[type="text"]:focus {
      outline: none;
      border-color: var(--accent-border);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
    }

    textarea::placeholder, input::placeholder { color: var(--text-light); }

    .notes-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px 14px;
      margin-bottom: 0.25rem;
    }

    .settings-toggle {
      font-size: 13px;
      color: var(--text-mid);
      cursor: pointer;
      margin-top: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-weight: 500;
      transition: color 0.15s;
    }

    .settings-toggle:hover { color: var(--accent); }

    .settings-panel {
      margin-top: 8px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
    }

    .settings-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 0;
      font-size: 13px;
      border-bottom: 1px solid var(--surface-alt);
    }

    .settings-row:last-child { border-bottom: none; }

    .freq-select {
      padding: 5px 8px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 12px;
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      font-weight: 500;
    }

    .gen-btn {
      width: 100%;
      margin-top: 1.5rem;
      padding: 14px;
      border-radius: var(--radius);
      border: none;
      background: var(--accent);
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      font-family: var(--font);
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      letter-spacing: -0.01em;
    }

    .gen-btn:hover { background: var(--accent-hover); }
    .gen-btn:active { transform: scale(0.98); }
    .gen-btn:disabled { opacity: 0.35; cursor: not-allowed; }

    .output-area {
      margin-top: 1rem;
      animation: fadeIn 0.2s ease;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    .output-box {
      padding: 1rem 1.25rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      font-size: 14px;
      line-height: 1.7;
      white-space: pre-wrap;
    }

    .copy-btn {
      margin-top: 8px;
      width: 100%;
      padding: 11px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 14px;
      font-family: var(--font);
      cursor: pointer;
      transition: all 0.15s;
      font-weight: 500;
    }

    .copy-btn:hover { background: var(--surface-alt); }

    .whatsapp-btn {
      margin-top: 6px;
      width: 100%;
      padding: 11px;
      border-radius: var(--radius);
      border: none;
      background: #25D366;
      color: #fff;
      font-size: 14px;
      font-family: var(--font);
      cursor: pointer;
      transition: all 0.15s;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .whatsapp-btn:hover { background: #20BD5A; }
    .whatsapp-btn:active { transform: scale(0.98); }

    @media (max-width: 480px) {
      .app { padding: 1rem 0.75rem 3rem; }
    }
  </style>
</head>
<body>

<div class="app">
  <div class="app-header">
    <div class="app-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    </div>
    <div>
      <div class="app-title">Tarefas Casa</div>
      <div class="app-subtitle">Mensagem para a Ana</div>
    </div>
  </div>

  <div class="section-label">Dia de trabalho</div>
  <div class="day-selector">
    <div class="day-btn active" onclick="selectDay(3)">4ª feira</div>
    <div class="day-btn" onclick="selectDay(4)">5ª feira</div>
  </div>

  <div class="section-label">Tarefas</div>
  <div id="tasks-container"></div>

  <div id="cook-extra" style="display:none;">
    <div class="meals-panel">
      <div class="sub-label" style="margin-top:0;">Refeições</div>
      <div class="meals-grid" id="meals-grid"></div>
      <div class="sub-label">Outras indicações (opcional)</div>
      <textarea id="cook-details" placeholder="Ex: deixar a sopa no frigorífico, usar o frango do congelador..." rows="2"></textarea>
    </div>
  </div>

  <div class="section-label">Notas adicionais</div>
  <div class="notes-box">
    <textarea id="notes-input" placeholder="Ex: a chave está debaixo do tapete, hoje vou chegar mais tarde..." rows="3"></textarea>
  </div>

  <span class="settings-toggle" onclick="toggleSettings()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.32 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    Periodicidade
  </span>
  <div id="settings-panel" class="settings-panel" style="display:none;"></div>

  <button class="gen-btn" id="gen-btn" disabled onclick="generateMessage()">Gerar mensagem para WhatsApp</button>

  <div id="output" class="output-area" style="display:none;">
    <div class="output-box" id="msg-output"></div>
    <button class="copy-btn" onclick="copyMessage()">Copiar mensagem</button>
    <button class="whatsapp-btn" onclick="openWhatsApp()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Abrir no WhatsApp
    </button>
  </div>
</div>

<script>
const MEALS = [
  'Sopa', 'Bacalhau com natas', 'Arroz de pato', 'Bolonhesa',
  'Quiche de cogumelos', 'Pão de queijo', 'Cuscuz com legumes',
  'Quinoa com legumes', 'Lasanha de carne', 'Lasanha de atum',
  'Bifinhos com cogumelos', 'Frango cozido para Bernardo'
];

const TASKS = [
  { id: 'limpeza', name: 'Limpeza geral', freq: 'weekly' },
  { id: 'limpezafundo', name: 'Limpeza a fundo', freq: 'monthly', lastDone: null },
  { id: 'lencoisbig', name: 'Trocar lençóis da cama de casal', freq: 'biweekly', lastDone: null },
  { id: 'lencoispeq', name: 'Trocar lençóis da cama do Bernardo', freq: 'biweekly', lastDone: null },
  { id: 'toalhas', name: 'Trocar toalhas de banho', freq: 'biweekly', lastDone: null },
  { id: 'cozinhar', name: 'Cozinhar', freq: 'weekly' },
  { id: 'arrumar', name: 'Arrumar a casa', freq: 'weekly' },
  { id: 'passar', name: 'Passar a ferro', freq: 'weekly' },
  { id: 'bernardo', name: 'Ir buscar o Bernardo à escola', freq: 'manual' },
];

const NOTE_INTROS = [
  'Ah, e só mais uma coisa:',
  'Já agora, só para avisar:',
  'Ah, e também queria dizer:',
  'Só uma nota:',
  'Ah, e outra coisa:',
];

let selectedDay = 3;
let checked = {};
let selectedMeals = {};
let showSettings = false;

// Load state from localStorage
function loadState() {
  try {
    const saved = localStorage.getItem('tarefas-ana-state');
    if (saved) {
      const state = JSON.parse(saved);
      TASKS.forEach(t => {
        if (state.lastDone && state.lastDone[t.id]) {
          t.lastDone = state.lastDone[t.id];
        }
        if (state.freqs && state.freqs[t.id]) {
          t.freq = state.freqs[t.id];
        }
      });
    }
  } catch(e) {}
}

function saveState() {
  try {
    const lastDone = {};
    const freqs = {};
    TASKS.forEach(t => {
      if (t.lastDone) lastDone[t.id] = t.lastDone;
      freqs[t.id] = t.freq;
    });
    localStorage.setItem('tarefas-ana-state', JSON.stringify({ lastDone, freqs }));
  } catch(e) {}
}

function getFreqLabel(f) {
  return f === 'weekly' ? 'Semanal' : f === 'biweekly' ? 'Quinzenal' : f === 'monthly' ? 'Mensal' : 'Pontual';
}

function selectDay(d) {
  selectedDay = d;
  document.querySelectorAll('.day-btn').forEach((b, i) => {
    b.classList.toggle('active', (i === 0 && d === 3) || (i === 1 && d === 4));
  });
}

function getNextDate(task) {
  if (task.freq === 'weekly' || task.freq === 'manual') return null;
  if (!task.lastDone) return 'Nunca feito — sugerido para hoje';
  const last = new Date(task.lastDone);
  const days = task.freq === 'biweekly' ? 14 : 30;
  const next = new Date(last.getTime() + days * 86400000);
  if (next <= new Date()) return 'Sugerido para hoje';
  return 'Próxima vez: ' + next.toLocaleDateString('pt-PT', { day: 'numeric', month: 'short' });
}

function toggleTask(id) {
  checked[id] = !checked[id];
  if (id === 'cozinhar') {
    document.getElementById('cook-extra').style.display = checked[id] ? 'block' : 'none';
  }
  renderTasks();
  updateBtn();
}

function toggleMeal(name) {
  selectedMeals[name] = !selectedMeals[name];
  renderMeals();
}

function updateBtn() {
  document.getElementById('gen-btn').disabled = !Object.values(checked).some(v => v);
}

function renderMeals() {
  const g = document.getElementById('meals-grid');
  g.innerHTML = '';
  MEALS.forEach(m => {
    const chip = document.createElement('span');
    chip.className = 'meal-chip' + (selectedMeals[m] ? ' selected' : '');
    chip.textContent = m;
    chip.onclick = () => toggleMeal(m);
    g.appendChild(chip);
  });
}

function renderTasks() {
  const c = document.getElementById('tasks-container');
  c.innerHTML = '';
  TASKS.forEach(t => {
    const isChecked = checked[t.id] || false;
    const row = document.createElement('div');
    row.className = 'task-row' + (isChecked ? ' checked' : '');
    row.onclick = () => toggleTask(t.id);
    const nextInfo = getNextDate(t);
    row.innerHTML = `
      <div class="task-check">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div style="flex:1;">
        <div class="task-label">${t.name}</div>
        ${nextInfo && t.freq !== 'weekly' && t.freq !== 'manual' ? '<div class="next-date">' + nextInfo + '</div>' : ''}
      </div>
      <span class="task-freq">${getFreqLabel(t.freq)}</span>
    `;
    c.appendChild(row);
  });
}

function toggleSettings() {
  showSettings = !showSettings;
  const panel = document.getElementById('settings-panel');
  if (!showSettings) { panel.style.display = 'none'; return; }
  panel.style.display = 'block';
  panel.innerHTML = '';
  TASKS.filter(t => t.freq !== 'manual').forEach(t => {
    const row = document.createElement('div');
    row.className = 'settings-row';
    row.innerHTML = `
      <span>${t.name}</span>
      <select class="freq-select" onchange="changeFreq('${t.id}', this.value)">
        <option value="weekly" ${t.freq === 'weekly' ? 'selected' : ''}>Semanal</option>
        <option value="biweekly" ${t.freq === 'biweekly' ? 'selected' : ''}>Quinzenal</option>
        <option value="monthly" ${t.freq === 'monthly' ? 'selected' : ''}>Mensal</option>
      </select>
    `;
    panel.appendChild(row);
  });
}

function changeFreq(id, val) {
  const t = TASKS.find(t => t.id === id);
  if (t) t.freq = val;
  saveState();
  renderTasks();
}

function generateMessage() {
  const selected = TASKS.filter(t => checked[t.id]);
  if (!selected.length) return;

  const dayName = selectedDay === 3 ? 'quarta-feira' : 'quinta-feira';
  let msg = `Olá Ana! Então para hoje (${dayName}) será para fazer o seguinte:\n\n`;

  selected.forEach(t => {
    if (t.id === 'cozinhar') {
      const meals = MEALS.filter(m => selectedMeals[m]);
      const extra = document.getElementById('cook-details').value.trim();
      if (meals.length || extra) {
        msg += `• Cozinhar:\n`;
        meals.forEach(m => { msg += `  - ${m}\n`; });
        if (extra) msg += `  - ${extra}\n`;
      } else {
        msg += `• Cozinhar\n`;
      }
    } else if (t.id === 'bernardo') {
      msg += `• Ir buscar o Bernardo à escola\n`;
    } else {
      msg += `• ${t.name}\n`;
    }
  });

  const notes = document.getElementById('notes-input').value.trim();
  if (notes) {
    const intro = NOTE_INTROS[Math.floor(Math.random() * NOTE_INTROS.length)];
    msg += `\n${intro} ${notes}`;
  }

  msg += `\n\nMuito obrigado! 🙏`;

  // Mark periodic tasks as done
  selected.forEach(t => {
    if (t.freq === 'biweekly' || t.freq === 'monthly') {
      t.lastDone = new Date().toISOString();
    }
  });
  saveState();

  document.getElementById('msg-output').textContent = msg;
  document.getElementById('output').style.display = 'block';

  // Scroll to output
  setTimeout(() => {
    document.getElementById('output').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }, 100);

  renderTasks();
}

function copyMessage() {
  const msg = document.getElementById('msg-output').textContent;
  navigator.clipboard.writeText(msg).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.textContent = 'Copiado!';
    setTimeout(() => btn.textContent = 'Copiar mensagem', 2000);
  });
}

function openWhatsApp() {
  const msg = document.getElementById('msg-output').textContent;
  const encoded = encodeURIComponent(msg);
  window.open('https://wa.me/?text=' + encoded, '_blank');
}

// Init
loadState();
renderTasks();
renderMeals();
</script>

</body>
</html>
